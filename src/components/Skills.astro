---
import { Code2, Brain, Users } from 'lucide-react';
---

<section id="skills" class="py-24 px-4 bg-slate-900/30">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Tech Stack</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-indigo-500 to-cyan-500 mx-auto rounded-full"></div>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Languages & Frameworks -->
      <div class="bg-slate-800/50 p-6 rounded-xl border border-indigo-500/30 card-hover" style="box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.3);">
<Code2 size={32} className="mb-4" color="#646cff" />        <h3 class="text-xl font-bold text-white mb-4">Languages & Frameworks</h3>
        <div class="flex flex-wrap gap-2">
          {['TypeScript', 'JavaScript', 'Node.js', 'React', 'Express'].map(skill => (
            <span class="bg-indigo-900/40 text-indigo-300 px-3 py-1 rounded-lg text-sm">{skill}</span>
          ))}
        </div>
      </div>

      <!-- AI & LLMs -->
      <div class="bg-slate-800/50 p-6 rounded-xl border border-blue-500/30 card-hover" style="box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.3);">
        <Brain size={32} className="text-blue-400 mb-4" />
        <h3 class="text-xl font-bold text-white mb-4">AI & LLMs</h3>
        <div class="flex flex-wrap gap-2">
          {['Genkit', 'LangChain', 'OpenAI API', 'Tavily', 'Gemini', 'ElevenLabs'].map(skill => (
            <span class="bg-blue-900/40 text-blue-300 px-3 py-1 rounded-lg text-sm">{skill}</span>
          ))}
        </div>
      </div>

      <!-- Backend & DevOps -->
      <div class="bg-slate-800/50 p-6 rounded-xl border border-cyan-500/30 card-hover" style="box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.3);">
        <Users size={32} className="text-cyan-400 mb-4" />
        <h3 class="text-xl font-bold text-white mb-4">Backend & DevOps</h3>
        <div class="flex flex-wrap gap-2">
          {['REST APIs', 'Docker', 'CI/CD', 'SQLite', 'Firebase', 'Git'].map(skill => (
            <span class="bg-cyan-900/40 text-cyan-300 px-3 py-1 rounded-lg text-sm">{skill}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>