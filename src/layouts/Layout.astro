---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "I leverage Clean Architecture and TypeScript to build scalable systems—like TenderCheck AI, which automates complex document validation through modular LLM pipelines. Focused on code quality, testability, and delivering real-world impact." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/images/EM_favicon_rounded.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>